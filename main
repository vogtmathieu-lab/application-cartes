    <div id="control-panel">
        <div class="input-group">
            <label>Route / Commune :</label>
            <input type="text" id="input-line1" value="D1004 - WASSELONNE" oninput="updateBanner()">
        </div>
        <div class="input-group">
            <label>Nature du chantier :</label>
            <input type="text" id="input-line2" value="TRAVAUX D'ENROBÉS DE NUIT" oninput="updateBanner()">
        </div>
        
        <div class="input-group" style="flex-direction: row; align-items: flex-end; gap: 6px;">
            <button class="btn btn-red" onclick="startDraw('Chantier', '#d32f2f', 7)">+ Chantier</button>
            <button class="btn btn-green" onclick="startDraw('PP', '#2e7d32', 5)">+ Déviation PP</button>
            <button class="btn btn-blue" onclick="startDraw('SEC', '#1565c0', 5)">+ Déviation SEC</button>
            <button class="btn btn-orange" onclick="startDraw('VL1', '#ff6b00', 5)">+ Déviation VL 1</button>
            <button class="btn btn-purple" onclick="startDraw('VL2', '#8e24aa', 5)">+ Déviation VL 2</button>
            <button class="btn btn-pink" onclick="startDraw('PL', '#e91e63', 5)">+ Déviation PL</button>
            
            <span style="border-left: 2px solid #ccc; margin: 0 4px; height: 35px;"></span>
            
            <button class="btn btn-validate" onclick="finishDraw()">✔️ Terminer le tracé</button>
            <button class="btn btn-cancel" onclick="stopDraw()">❌ Annuler</button>
        </div>

        <button class="btn btn-export" onclick="exportPlan()">💾 Exporter Image (PNG)</button>
        
        <div id="help-tip">
            <strong>🖱️ Magnétisme Actif :</strong> Cliquez sur vos points de passage, le tracé suit automatiquement les routes. Validez avec <strong>✔️ Terminer</strong>.
        </div>
