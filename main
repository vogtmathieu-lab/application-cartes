        #help-tip { width: 100%; background: #e3f2fd; border-left: 4px solid #1e88e5; padding: 8px 12px; font-size: 13px; color: #0d47a1; border-radius: 0 4px 4px 0; margin-top: -5px; }
        #export-container { width: 1024px; height: 768px; margin: 0 auto; background: #104169; padding: 15px; box-sizing: border-box; border-radius: 4px; box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
        #banner { width: 100%; height: 90px; background: #104169; color: white; border: 3px solid white; box-sizing: border-box; }
